# Copy this file to .env.wayland for manual testing, or to:
# /etc/stringcast/wayland-listener.env
#
# Keep the copied file private:
# chmod 600 .env.wayland

# Required unless provider-specific key variables are set.
STRINGCAST_API_KEY=

# Supported values in the Python PoC: gemini, openai, claude, grok.
STRINGCAST_PROVIDER=openai
STRINGCAST_MODEL=gpt-4o-mini
STRINGCAST_TRIGGER=?fix

# Optional. Leave empty to use provider defaults.
STRINGCAST_API_URL=

# Optional comma-separated provider-specific keys.
GEMINI_API_KEYS=
OPENAI_API_KEYS=
ANTHROPIC_API_KEYS=
XAI_API_KEYS=

# Optional provider-specific models.
STRINGCAST_GEMINI_MODEL=gemini-2.0-flash
STRINGCAST_OPENAI_MODEL=gpt-4o-mini
STRINGCAST_CLAUDE_MODEL=claude-3-5-sonnet-20240620
STRINGCAST_GROK_MODEL=grok-2-latest
